{
  "expo": {
    "name": "ATSS",
    "slug": "atss",
    "scheme": "atss-app",
    "version": "2.5.44",
    "orientation": "portrait",
    "icon": "./assets/applogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/applogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atss.sync",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "name": "ATSS",
      "icon": "./assets/applogo.png",
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/applogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.atss.sync",
      "launchMode": "singleTask",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyACI3bm9Mno0-DeH3BiSQ69Y_wSV_PMe9g"
        }
      },
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/jo.mp3",
            "./assets/sounds/so.mp3",
            "./assets/sounds/wo.mp3"
          ]
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow ATSS to access your photos to select job order images.",
          "savePhotosPermission": "Allow ATSS to save taken photos to your phone gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ATSS to access your photos to select job order images.",
          "cameraPermission": "Allow ATSS to access your camera to take job order pictures."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0002ea40-23dc-4f5d-98da-82c2ab259bfa"
      }
    }
  }
}